APP_NAME=Method-Aware Framework
API_PREFIX=/api/v1
# Database init behavior. Defaults to migrate when unset.
# DB_INIT_MODE=none
# PostgreSQL (Tier1 operator default example):
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/method_aware
# SQLite fallback:
# DATABASE_URL=sqlite:///./method_aware.db
STORAGE_DIR=app/storage
MAX_UPLOAD_MB=64

SCIENCEBASE_API_BASE_URL=https://www.sciencebase.gov/catalog
NRC_ADAMS_APS_API_BASE_URL=https://adams-api.nrc.gov
NRC_ADAMS_APS_SUBSCRIPTION_KEY=replace_with_your_real_key

CONNECTOR_LEASE_TTL_SECONDS=120
CONNECTOR_SUBMISSION_TTL_HOURS=24
CONNECTOR_MAX_REDIRECTS=3
CONNECTOR_MAX_CONCURRENT_RUNS=1
CONNECTOR_MAX_DOWNLOADS_PER_RUN=1
CONNECTOR_PER_HOST_FETCH_LIMIT=2
